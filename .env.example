# Copy this file to .env and fill in your values
# TuracoFlow uses only local/free services — no paid API keys required

# Ollama settings (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TEXT_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text

# LanceDB settings (local, no compilation needed)
LANCEDB_PATH=./lancedb
LANCEDB_TABLE_NAME=turaco_policies

# Claims database (SQLite, local)
SQLITE_DB_PATH=./claims.db

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Confidence threshold — below this, claim goes to human review
CONFIDENCE_THRESHOLD=0.75
